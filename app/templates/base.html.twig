<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}SPA Symfony{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <style>
            :root {
                --bg: #f5f4ef;
                --surface: #ffffff;
                --text: #2d2b26;
                --muted: #6f6a61;
                --line: #dfdbd1;
                --accent: #8a6a3a;
            }
            body {
                margin: 0;
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                background: var(--bg);
                color: var(--text);
                line-height: 1.5;
            }
            .container {
                max-width: 920px;
                margin: 0 auto;
                padding: 2rem 1rem 3rem;
            }
            .hero {
                background: linear-gradient(180deg, #f3efe4 0%, #faf8f1 100%);
                border: 1px solid var(--line);
                border-radius: 14px;
                padding: 2rem 1.5rem;
                margin-bottom: 1.2rem;
            }
            .hero h1 {
                margin: 0 0 0.5rem;
                font-size: 2rem;
                font-weight: 500;
            }
            .hero p {
                margin: 0;
                color: var(--muted);
            }
            .card {
                background: var(--surface);
                border: 1px solid var(--line);
                border-radius: 12px;
                padding: 1.2rem;
                margin-bottom: 1.2rem;
                box-shadow: 0 2px 6px rgba(31, 24, 15, 0.04);
            }
            h2 {
                margin: 0 0 0.7rem;
                font-size: 1.2rem;
                font-weight: 500;
            }
            .flash-success {
                background: #eaf4ea;
                border: 1px solid #b4d2b5;
                color: #2f5130;
                border-radius: 8px;
                padding: 0.75rem;
                margin-bottom: 1rem;
            }
            label {
                display: block;
                margin-top: 0.75rem;
                margin-bottom: 0.35rem;
                color: var(--muted);
                font-size: 0.93rem;
            }
            input, textarea {
                width: 100%;
                border: 1px solid #d1ccc1;
                border-radius: 8px;
                padding: 0.6rem;
                box-sizing: border-box;
                font-size: 0.95rem;
                background: #fcfbf8;
                color: var(--text);
            }
            button {
                margin-top: 1rem;
                background: var(--accent);
                color: #fdfbf7;
                border: 0;
                border-radius: 8px;
                padding: 0.62rem 1.05rem;
                cursor: pointer;
                letter-spacing: 0.2px;
            }
            button:hover {
                background: #77582f;
            }
        </style>
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
